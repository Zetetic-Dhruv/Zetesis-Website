{
  "name": "zetesis-website",
  "version": "1.0.0",
  "description": "Minimal, academic-styled website for Zetesis Labs.",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./output.css",
    "prerender:github": "node scripts/prerender-github.js",
    "indexnow": "node scripts/indexnow-ping.js",
    "build": "npm run build:css && rm -rf dist && mkdir -p dist && cp index.html lab.html output.css CNAME ping.html robots.txt sitemap.xml llms.txt 9b9e2a83c35fb9e6e7a601e0acb2510e.txt dist/ && touch dist/.nojekyll && cp -r public dist/ && npm run prerender:github",
    "dev": "tailwindcss -i ./src/input.css -o ./output.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhruvgupta-zetesis/Zetesis-Website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dhruvgupta-zetesis/Zetesis-Website/issues"
  },
  "homepage": "https://github.com/dhruvgupta-zetesis/Zetesis-Website#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  }
}